API_PORT=3000
CORS_ORIGIN=http://localhost:3001
REQUEST_BODY_LIMIT=1mb

DB_EXPOSE_PORT=3306
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=soren_store
DB_USERNAME=change_me_db_user
DB_PASSWORD=change_me_db_password
DB_ROOT_PASSWORD=change_me_db_root_password
DB_SYNCHRONIZE=true
DB_LOGGING=false
DB_USE_MIGRATIONS=false
SEED_ON_BOOT=true

JWT_ACCESS_SECRET=change_me_jwt_access_secret
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret
PAYMENTS_WEBHOOK_SECRET=change_me_payments_webhook_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=8
INVENTORY_RESERVATION_TTL_MINUTES=15
SMS_PROVIDER_ENABLED=false

SEED_ADMIN_EMAIL=change_me_admin_email@example.com
SEED_ADMIN_PASSWORD=change_me_admin_password
